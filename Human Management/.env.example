# --- server/.env ---
DATABASE_FILE=./data/app.db
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# --- client/.env ---
VITE_API_BASE_URL=http://localhost:3001/api

# When deploying to production, switch DATABASE_FILE for a Supabase/Postgres
# DATABASE_URL and re-enable Supabase Auth (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
# VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY).
